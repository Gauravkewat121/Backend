        "/auth/user/project-details/{projectId}": {
            "get": {
                "summary": "Get project details",
                "tags": [
                    "Project"
                ],
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "projectId",
                        "in": "path",
                        "required": true,
                        "description": "Project ID",
                        "schema": {
                            "type": "string",
                            "example": "605c72ef153207001f786e60"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Project details retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "_id": {
                                                "type": "string",
                                                "example": "605c72ef153207001f786e60"
                                            },
                                            "name": {
                                                "type": "string",
                                                "example": "Project Alpha"
                                            },
                                            "createdAt": {
                                                "type": "string",
                                                "format": "date-time",
                                                "example": "2022-01-15T12:30:00Z"
                                            },
                                            "creator": {
                                                "type": "string",
                                                "example": "creator@example.com"
                                            },
                                            "projectTasks": {
                                                "type": "array",
                                                "items": {
                                                    "type": "object",
                                                    "properties": {
                                                        "_id": {
                                                            "type": "string",
                                                            "example": "605c72ef153207001f786e60"
                                                        },
                                                        "taskName": {
                                                            "type": "string",
                                                            "example": "Task 1"
                                                        },
                                                        "status": {
                                                            "type": "boolean",
                                                            "example": false
                                                        },
                                                        "createdAt": {
                                                            "type": "string",
                                                            "format": "date-time",
                                                            "example": "2022-01-16T14:30:00Z"
                                                        },
                                                        "updatedAt": {
                                                            "type": "string",
                                                            "format": "date-time",
                                                            "example": "2022-01-16T14:30:00Z"
                                                        },
                                                        "assignedTo": {
                                                            "type": "string",
                                                            "example": "user@example.com"
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/auth/project/create-task/{projectId}/{developerId}": {
            "post": {
                "tags": [
                    "Task"
                ],
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "summary": "create task of project ",
                "operationId": "createTask",
                "parameters": [
                    {
                        "in": "path",
                        "name": "projectId",
                        "required": true,
                        "description": "project id",
                        "schema": {
                            "type": "string"
                        },
                        "example": 5
                    },
                    {
                        "in": "path",
                        "name": "developerId",
                        "required": true,
                        "description": "developer id",
                        "schema": {
                            "type": "string"
                        },
                        "example": 5
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "taskName": {
                                        "type": "string",
                                        "description": "name of the task",
                                        "example": "The Task Management"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "user creates a task",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "task created successfully"
                                        },
                                        "task": {
                                            "type": "object",
                                            "properties": {
                                                "_id": {
                                                    "type": "string"
                                                },
                                                "taskName": {
                                                    "type": "string"
                                                },
                                                "createdAt": {
                                                    "type": "date-time"
                                                },
                                                "updatedAt": {
                                                    "type": "date-time"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
